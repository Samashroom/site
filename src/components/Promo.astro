---
import promoimage from "../assets/promo-image.png";
---

<article class="promo">
  <h2 class="promo__title">Последние новости:</h2>
  <div class="promo__container">
    <div class="promo__imagecontainer">
      <img class="promo__image" src={promoimage.src} alt="Промо изображение" />
    </div>

    <p class="promo__description">27.06.2025 - Стрим с просмотром УЦЦ</p>
  </div>
</article>

<style>
  .promo {
    border-radius: 10px;
    margin: 20px 0;
    text-align: center;
    display: flex;
    flex-direction: column;
   align-items: center;
    
    background: linear-gradient(135deg, #f0f0f0a9, #dcdcdca1);
    box-shadow:
      inset 0 0 30px rgba(0, 255, 255, 0.692),
      inset 0 -10px 10px rgba(0, 0, 0, 0.562);
  }

  .promo__title {
    font-size: 24px;
    margin-bottom: 15px;
    color: #ff0000;
    text-transform: uppercase;
    background: yellow;
  }
  .promo__imagecontainer {
    width: 90%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    object-fit: cover;
  }

  .promo__container {
    width: fit-content;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px;
  }
  .promo__image {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow:
      0 0 30px rgba(0, 255, 255, 0.692),
      inset 0 -10px 10px rgba(0, 0, 0, 0.562);
  }

  .promo__description {
    text-transform: uppercase;
    font-size: 22px;
    color: #122e57;
    margin-top: 15px;
  }
</style>
