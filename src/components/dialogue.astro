---
import Photo from '../components/photo.astro';
---

<div>

    <div class="dialogue">
        <Photo />
        <div>
            <h2>Велкам на сайт САМАШРУМ!</h2>
            <p class="dialogue__line">* Да, это мой сайт. Он в разработке, но тут прикольно!</p>
        </div>
        
    </div>
</div>

<style>
    .dialogue {
        
        margin: 20px auto;
        border-radius: 15px;
        color: #00ff00;
        font-family: 'Arial', sans-serif;
        background: linear-gradient( #00000081, #000000c9);
        box-shadow: 0 4px 90px rgb(255, 255, 255);
        position: relative;
        display: flex;
        gap: 20px;
        animation: fadeInUp 0.5s ease-out;
        box-shadow:
      inset 0 0 30px rgba(0, 255, 255, 0.3),
      inset 0 -10px 10px rgba(0, 0, 0, 0.1);
    }

    .dialogue h2{
        font-size: 36px;
    }
    @media (max-width: 600px) {
        .dialogue {
            flex-direction: column;
            text-align: center;
            align-items: center;
            padding: 20px;
        }
    }
    
    @keyframes fadeInUp {
        from {
        opacity: 0;
        transform: translateY(20px);
        }
        to {
        opacity: 1;
        transform: translateY(0);
        }
</style>